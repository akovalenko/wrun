# Tools the target lisp spawns with run-program during the build.
# sb-grovel invokes $CC — with the toolchain dir on PATH that is
# plain "gcc"/"cc" resolving to the cross compiler:
gcc
cc
# handy for tests / interactive use:
cat
# the suite's sh tests: the child lisp spawns `sh <file>.test.sh`;
# the script then re-enters the target through TEST_SBCL_RUNTIME.
sh
# bare names the suite's run-program tests spawn (run-program.test.sh):
true
false
printf
